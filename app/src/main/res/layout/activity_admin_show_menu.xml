<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".admin.AdminShowMenuActivity">

    <LinearLayout
        style="@style/PageLinear">

        <LinearLayout
            android:layout_marginBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/back"
                android:background="#f1f1f1"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/ic_back" />

            <TextView
                style="@style/H1"
                android:layout_weight="1"
                android:text="Menu Details"

                />


            <TextView
                android:id="@+id/edit"
                style="@style/Label"
                android:textColor="#0000FF"
                android:text="Edit Details"

                />

        </LinearLayout>

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="fitCenter"
            tools:srcCompat="@tools:sample/backgrounds/scenic" />



    <LinearLayout
        android:layout_marginVertical="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            style="@style/H1"
            android:layout_weight="1"
            android:text="Chicken Adobo"

            />


        <TextView
            style="@style/H1"
            android:text="$150.00"

            />
    </LinearLayout>


        <TextView
            style="@style/H2"
            android:layout_weight="1"
            android:text="Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo Chicken Adobo"

            />

    </LinearLayout>


</androidx.appcompat.widget.LinearLayoutCompat>